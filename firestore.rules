rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile + subcollections
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
      }

      // Alarms subcollection
      match /alarms/{alarmId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Interaction tracking — user writes their own, no reads (server-side only)
    match /interactions/{uid}/{docId} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if false;
    }

    // Rate limiting — server-managed, no client access
    match /rate_limits/{uid} {
      allow read, write: if false;
    }

    // Admin keys — server-managed only, never client-accessible
    match /admin_keys/{uid} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
